# ──────────────────────────────────────────────────────────────
# GOODPRICE — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# ──────────────────────────────────────────────────────────────

# ── Site URL ──────────────────────────────────────────────────
# Used to build absolute URLs in email templates and sitemaps.
# Include protocol, no trailing slash.
NEXT_PUBLIC_SITE_URL=https://www.goodprice.co

# ── Admin Panel Authentication ────────────────────────────────
# El panel /admin usa HTTP Basic Auth con contraseña DINÁMICA derivada de la
# fecha actual en zona horaria Bogotá (UTC-5).
#
# Formato: GP<DD><MM><YY>D
# Ejemplo 29 de mayo de 2026 → GP290526D
#
# La contraseña cambia automáticamente cada día a medianoche (hora Bogotá).
# NO es necesario configurar ninguna variable de entorno para la autenticación.
# El middleware.ts calcula la contraseña en tiempo de ejecución.
#
# Usuario fijo:    good_price
# Contraseña:      GP<DD><MM><YY>D  (se calcula automáticamente)
#
# NOTA: La variable ADMIN_PASSWORD que aparecía aquí anteriormente NO existe
# en el sistema — el middleware no la lee. Esta sección documenta el
# comportamiento real.

# ── Vercel Cron Authentication ────────────────────────────────
# Secret token sent automatically by Vercel Cron on every job invocation.
# Vercel Cron sends this as: Authorization: Bearer {CRON_SECRET}
# Generate: openssl rand -hex 32
CRON_SECRET=your-secret-token-here

# ── Audit / PA-API Endpoint Secret ───────────────────────────
# Optional secondary secret for manually triggering:
#   POST /api/audit/run
#   POST /api/paapi/sync
# from external tools (curl, CI pipeline, etc.).
# If not set, only CRON_SECRET is accepted (plus no-auth in dev).
# Generate: openssl rand -hex 32
AUDIT_SECRET=your-audit-secret-here

# ── Pricing Store Adapter ─────────────────────────────────────
# Which store backend to use for pricing data.
# "file"     → JSON files in data/pricing/ (local dev only)
# "supabase" → Supabase Postgres (production — not yet implemented)
PRICING_STORE_ADAPTER=file

# ── Resend Email (price alert notifications) ──────────────────
# Required to send email alerts when a subscription triggers.
# Sign up at https://resend.com — free tier: 100 emails/day, 3,000/month.
#
# RESEND_API_KEY:    Your API key (starts with re_...)
# RESEND_FROM_EMAIL: Verified sender — must match a domain you've verified
#                    in the Resend dashboard. Format: "Name <email@domain.com>"
#
# Without RESEND_API_KEY, alert detection still runs but emails are skipped.
# Alerts are logged to console with status "skipped_no_api_key".
RESEND_API_KEY=re_your-resend-key-here
RESEND_FROM_EMAIL=GOODPRICE <alertas@goodprice.co>

# ── Alert Cooldown ────────────────────────────────────────────
# Minimum hours between consecutive emails for the same subscription.
# Prevents spam when a price oscillates around an alert threshold.
# Default: 24 (one email per day maximum per subscription)
ALERT_COOLDOWN_HOURS=24

# ── Google Search Console verification ───────────────────────
# From: https://search.google.com/search-console → Add Property → "HTML tag" method
# Copy ONLY the content= value (not the full <meta> tag). Set before deploying.
# GOOGLE_SITE_VERIFICATION=your-gsc-verification-token

# ── Bing Webmaster Tools verification ────────────────────────
# From: https://www.bing.com/webmasters → Add Site → "Meta tag" method
# Copy ONLY the content= value.
# BING_SITE_VERIFICATION=your-bing-verification-token

# ── Analytics persistence (Upstash Redis / Vercel KV) ────────
# Without this, product click + category view analytics reset on every cold start.
# Free tier: https://vercel.com/storage/kv  (or https://console.upstash.com)
# After adding Vercel KV to your project, these vars are set automatically.
# KV_REST_API_URL=https://your-kv.upstash.io
# KV_REST_API_TOKEN=AXXXxxx

# ── Future: Supabase (Phase N+3) ─────────────────────────────
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Future: MercadoLibre API OAuth (Phase N+4) ───────────────
# Required for higher rate limits (3,000 req/hour vs 60 req/min public)
# ML_APP_ID=your-ml-app-id
# ML_CLIENT_SECRET=your-ml-client-secret
# ML_ACCESS_TOKEN=your-ml-access-token

# ── Amazon PA-API 5.0 — imágenes y metadata oficiales ────────
# Obtén credenciales en:
#   https://affiliate-program.amazon.com/assoc_credentials/home
#
# PAAPI_ACCESS_KEY   — Access Key ID (20 chars, all caps)
# PAAPI_SECRET_KEY   — Secret Access Key (40 chars, base64)
# PAAPI_PARTNER_TAG  — Tu Associate tag (upgoodprice-20 por defecto)
# PAAPI_MARKETPLACE  — Marketplace (www.amazon.com por defecto)
#
# Sin estas variables: el sync de imágenes queda deshabilitado
# y el admin mostrará "No configurado".
#
PAAPI_ACCESS_KEY=your-access-key-id
PAAPI_SECRET_KEY=your-secret-access-key
PAAPI_PARTNER_TAG=upgoodprice-20
# PAAPI_MARKETPLACE=www.amazon.com
