{
  "compilerOptions": {
    "lib": ["esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": false,
    "jsx": "preserve",
    "paths": {
      "@/*": ["./*"]
    },
    "baseUrl": "."
  },
  "include": ["scripts/**/*.ts", "lib/**/*.ts", "types/**/*.ts", "data/**/*.ts"]
}
